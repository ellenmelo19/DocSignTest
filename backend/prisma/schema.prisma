generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Document {
  id        String   @id @default(uuid())
  titulo    String
  descricao String
  status    Status   @default(PENDENTE)
  criado_em DateTime @default(now())

  @@map("documents")
}

enum Status {
  PENDENTE
  ASSINADO
}